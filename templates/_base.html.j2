<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% set _seo = seo|default({}) %}
  <title>{{ _seo.title|default('The UAP Index') }}</title>
  <meta name="description" content="{{ _seo.description|default('Daily UAP records, cases, documents, and claim-checking tools.') }}">
  {% if _seo.keywords %}<meta name="keywords" content="{{ _seo.keywords }}">{% endif %}
  <link rel="canonical" href="{{ _seo.canonical|default('') }}">
  <meta property="og:type" content="{{ _seo.og_type|default('website') }}">
  <meta property="og:site_name" content="{{ _seo.site_name|default('The UAP Index') }}">
  <meta property="og:title" content="{{ _seo.title|default('The UAP Index') }}">
  <meta property="og:description" content="{{ _seo.description|default('') }}">
  <meta property="og:image" content="{{ _seo.og_image|default('') }}">
  {% if jsonld %}<script type="application/ld+json">{{ jsonld|safe }}</script>{% endif %}
  <style>
    :root{--ink:#152033;--muted:#617089;--line:#dbe3ef;--paper:#fff;--wash:#f6f8fb;--blue:#183a66;--red:#b3262f;--green:#167044;--gold:#9a6a00;--font:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;--serif:Georgia,"Times New Roman",serif}*{box-sizing:border-box}body{margin:0;font-family:var(--font);color:var(--ink);background:#fff;line-height:1.6}a{color:var(--blue);text-decoration:none}a:hover{text-decoration:underline}.top-nav{background:var(--blue);color:#fff}.top-nav-inner{max-width:1120px;margin:0 auto;padding:14px 22px;display:flex;align-items:center;justify-content:space-between;gap:20px}.brand{font-family:var(--serif);font-weight:700;font-size:22px;color:#fff}.nav-links{display:flex;gap:18px;align-items:center;flex-wrap:wrap}.nav-links a{color:#fff;font-size:13px;text-transform:uppercase;letter-spacing:.08em;font-weight:700}.container{max-width:820px;margin:0 auto;padding:26px 22px}.container-wide{max-width:1120px;margin:0 auto;padding:26px 22px}.breadcrumbs{font-size:13px;color:var(--muted);margin:0 0 16px}.eyebrow{font-size:12px;text-transform:uppercase;letter-spacing:.12em;font-weight:800;color:var(--red)}h1,h2,h3{font-family:var(--serif);line-height:1.2}h1{font-size:40px;margin:8px 0 12px}h2{font-size:26px;margin:34px 0 14px}.lede{font-size:18px;color:var(--muted);font-family:var(--serif);font-style:italic}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;margin:22px 0}.card{border:1px solid var(--line);border-radius:6px;padding:18px;background:#fff}.card h3{font-size:19px;margin:0 0 8px}.meta{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em}.pill{display:inline-flex;border-radius:999px;border:1px solid var(--line);padding:3px 9px;font-size:12px;font-weight:700;color:var(--blue);margin:2px 4px 2px 0}.search-panel{background:var(--wash);border-left:4px solid var(--blue);padding:16px;margin:18px 0}.search-row{display:flex;gap:8px;flex-wrap:wrap}.search-row input,.search-row select{flex:1 1 190px;padding:11px 12px;border:1px solid var(--line);border-radius:4px;font:inherit}.search-row button{padding:11px 16px;border:0;border-radius:4px;background:var(--blue);color:#fff;font-weight:800}.entry{border-bottom:1px solid var(--line);padding:20px 0}.entry h3{margin:0 0 8px}.status-resolved{color:var(--green)}.status-unresolved,.status-contested{color:var(--red)}.status-under_review{color:var(--gold)}.footer{margin-top:50px;background:#10233c;color:#d7e0ef;text-align:center;padding:26px;font-size:13px}.footer a{color:#fff}@media(max-width:760px){h1{font-size:32px}.top-nav-inner{align-items:flex-start;flex-direction:column}.nav-links{gap:12px}}
  </style>
</head>
<body>
<nav class="top-nav"><div class="top-nav-inner"><a class="brand" href="/">The UAP Index</a><div class="nav-links"><a href="/briefing">Briefing</a><a href="/cases">Cases</a><a href="/documents">Documents</a><a href="/tools">Tools</a><a href="/timeline">Timeline</a><a href="/sources">Sources</a></div></div></nav>
{% block content %}{% endblock %}
<footer class="footer"><p>&copy; {{ current_year|default(2026) }} The UAP Index. Source-labeled public-record navigation, not proof beyond cited materials.</p><p><a href="/sources">Sources and methodology</a> · <a href="/tools/uap-claim-checker">Claim checker</a></p></footer>
</body></html>

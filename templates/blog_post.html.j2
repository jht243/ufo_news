{% extends "_base.html.j2" %}{% block content %}<main class="container"><div class="breadcrumbs"><a href="/briefing">Briefing</a></div><h1>{{ post.title }}</h1><p class="lede">{{ post.subtitle }}</p><div class="meta">{{ post.published_date }} · {{ post.reading_minutes or 1 }} min read</div>{% if post.takeaways_json %}<div class="card"><h3>Key Labels</h3><ul>{% for t in post.takeaways_json %}<li>{{ t }}</li>{% endfor %}</ul></div>{% endif %}<article>{{ post.body_html|safe }}</article>{% if post.canonical_source_url %}<p><a href="{{ post.canonical_source_url }}" rel="nofollow">Open primary source</a></p>{% endif %}</main>{% endblock %}
{% extends "_base.html.j2" %}{% block content %}<main class="container-wide"><div class="breadcrumbs"><a href="/tools">Tools</a> / Claim Checker</div><h1>UAP Claim Checker</h1><p class="lede">Paste a claim, case name, witness, or video title. The checker returns matching seeded cases and indexed source records.</p><form class="search-panel" method="get"><div class="search-row"><input name="q" value="{{ q }}" placeholder="Try GoFast, AARO, triangle lights, Puerto Rico object"><button>Check</button></div></form>{% if q %}<h2>Case matches</h2><div class="grid">{% for c in cases %}<article class="card"><div class="meta">{{ c.status|replace('_',' ') }} · {{ grades[c.slug].label }}</div><h3><a href="/cases/{{ c.slug }}">{{ c.title }}</a></h3><p>{{ c.official_explanation }}</p></article>{% else %}<p>No seeded case match.</p>{% endfor %}</div><h2>Source matches</h2>{% for r in rows %}<article class="entry"><div class="meta">{{ r.published_date }} · {{ r.source_name }} · {{ (r.analysis_json or {}).get('confidence_label','Source-labeled') }}</div><h3><a href="{{ r.source_url }}" rel="nofollow">{{ r.headline }}</a></h3><p>{{ (r.analysis_json or {}).get('takeaway','Indexed source record.') }}</p></article>{% else %}<p>No indexed source match yet.</p>{% endfor %}{% endif %}</main>{% endblock %}
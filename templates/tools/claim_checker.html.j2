{% extends "_base.html.j2" %}{% block content %}<main class="container-wide"><div class="breadcrumbs"><a href="/tools">Tools</a> / Check a UFO Story or Viral Video</div><div class="eyebrow">Stories people share</div><h1>Check a UFO Story or Viral Video</h1><p class="lede">Look up things people say about UFO videos or incidents, then see what the original sources actually support.</p><form class="search-panel" method="get"><div class="search-row"><input name="q" value="{{ q }}" placeholder="Search GoFast, transmedium, triangle, NARA, Puerto Rico"><select name="year"><option value="">All years</option>{% for y in facets.claim_years %}<option value="{{ y }}" {% if selected.year==y %}selected{% endif %}>{{ y }}</option>{% endfor %}</select><select name="category"><option value="">All categories</option>{% for cat in facets.claim_categories %}<option value="{{ cat }}" {% if selected.category==cat %}selected{% endif %}>{{ cat }}</option>{% endfor %}</select><select name="status"><option value="">All statuses</option>{% for s in facets.statuses %}<option value="{{ s }}" {% if selected.status==s %}selected{% endif %}>{{ s|replace('_',' ') }}</option>{% endfor %}</select><select name="case"><option value="">All cases</option>{% for slug,title in facets["cases"] %}<option value="{{ slug }}" {% if selected.case==slug %}selected{% endif %}>{{ title }}</option>{% endfor %}</select><select name="group"><option value="year" {% if group_key=='year' %}selected{% endif %}>Group by year</option><option value="location" {% if group_key=='location' %}selected{% endif %}>Group by location</option><option value="category" {% if group_key=='category' %}selected{% endif %}>Group by category</option><option value="status" {% if group_key=='status' %}selected{% endif %}>Group by status</option></select><button>Search</button></div></form><div class="meta">{{ claims|length }} source-backed stories</div>{% for group in claim_groups %}<section class="entry"><h2>{{ group.label }}</h2><div class="grid">{% for claim in group["items"] %}<article class="card"><div class="meta">{{ claim.date_label }} · {{ claim.location }} · {{ claim.category }}</div><h3>{{ claim.claim }}</h3><p><span class="pill status-{{ claim.status }}">{{ claim.status|replace('_',' ') }}</span><span class="pill">{{ claim.evidence_level|replace('_',' ') }}</span></p><p><strong>What is actually sourced:</strong> {{ claim.what_is_sourced }}</p><p><strong>Still open:</strong> {{ claim.open_questions }}</p><p>{% if claim.case_slug %}<a href="/cases/{{ claim.case_slug }}">Open case file</a> · {% endif %}{% for d in claim.documents %}<a href="{{ d.url }}" rel="nofollow">{{ d.source_name }} document</a>{% if not loop.last %} · {% endif %}{% endfor %}</p></article>{% endfor %}</div></section>{% else %}<p>No stories match those filters.</p>{% endfor %}{% if q and rows %}<h2>Scraped source matches</h2>{% for r in rows %}<article class="entry"><div class="meta">{{ r.published_date }} · {{ r.source_name }} · {{ (r.analysis_json or {}).get('confidence_label','Source-labeled') }}</div><h3><a href="{{ r.source_url }}" rel="nofollow">{{ r.headline }}</a></h3><p>{{ (r.analysis_json or {}).get('takeaway','Indexed source record.') }}</p></article>{% endfor %}{% endif %}</main>{% endblock %}

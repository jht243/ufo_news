{% extends "_base.html.j2" %}{% block content %}<main class="container-wide"><div class="breadcrumbs"><a href="/">Home</a> / Documents</div><h1>{% if tool_mode %}UAP Document Finder{% else %}UAP Documents{% endif %}</h1><p class="lede">Filter indexed records by source, year, and evidence level.</p><form class="search-panel" method="get"><div class="search-row"><input name="source" value="{{ filters.source|default('') }}" placeholder="source: aaro_cases, nara_uap"><input name="evidence" value="{{ filters.evidence|default('') }}" placeholder="evidence: official_record"><input name="year" value="{{ filters.year|default('') }}" placeholder="year"><button>Filter</button></div></form>{% for r in rows %}<article class="entry"><div class="meta">{{ r.published_date }} · {{ r.source.value }} · {{ (r.analysis_json or {}).get('evidence_level','general_news') }}</div><h3><a href="{{ r.source_url }}" rel="nofollow">{{ r.headline }}</a></h3><p>{{ (r.analysis_json or {}).get('takeaway','Indexed source record.') }}</p></article>{% else %}<p>No indexed documents yet.</p>{% endfor %}</main>{% endblock %}
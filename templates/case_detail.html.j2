{% extends "_base.html.j2" %}{% block content %}<main class="container"><div class="breadcrumbs"><a href="/cases">Cases</a> / {{ case.title }}</div><div class="eyebrow">{{ case.status|replace('_',' ') }} · {{ grade.label }} · {{ grade.score }}/100</div><h1>{{ case.title }}</h1><p class="lede">{{ case.location }} · {{ case.event_date }}</p><h2>Official Explanation</h2><p>{{ case.official_explanation }}</p><h2>Unresolved Questions</h2><ul>{% for q in case.unresolved_questions %}<li>{{ q }}</li>{% endfor %}</ul><h2>Sources</h2><ul>{% for s in case.source_urls %}<li><a href="{{ s.url }}" rel="nofollow">{{ s.label }}</a></li>{% endfor %}</ul><h2>Related Indexed Records</h2>{% for r in related %}<article class="entry"><div class="meta">{{ r.published_date }} · {{ r.source_name }}</div><h3><a href="{{ r.source_url }}" rel="nofollow">{{ r.headline }}</a></h3></article>{% else %}<p>No related scraped records yet.</p>{% endfor %}</main>{% endblock %}
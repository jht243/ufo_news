{% extends "_base.html.j2" %}{% block content %}<main class="container"><div class="breadcrumbs"><a href="/cases">Cases</a> / {{ case.title }}</div><div class="eyebrow">{{ case.status|replace('_',' ') }} · {{ grade.label }} · {{ grade.score }}/100</div><h1>{{ case.title }}</h1><p class="lede">{{ case.location }} · {{ case.event_date }}</p><h2>Official Explanation</h2><p>{{ case.official_explanation }}</p><h2>Claims Tracked</h2>{% for claim in claims %}<article class="entry"><div class="meta">{{ claim.date_label }} · {{ claim.category }} · {{ claim.confidence_label }}</div><h3>{{ claim.claim }}</h3><p><strong>What is sourced:</strong> {{ claim.what_is_sourced }}</p><p><strong>Still open:</strong> {{ claim.open_questions }}</p></article>{% else %}<p>No seeded claims attached yet.</p>{% endfor %}<h2>Original Documents</h2>{% for d in documents %}<article class="entry"><div class="meta">{{ d.date_label }} · {{ d.document_type }} · {{ d.evidence_level|replace('_',' ') }}</div><h3><a href="{{ d.url }}" rel="nofollow">{{ d.title }}</a></h3><p>{{ d.summary }}</p></article>{% else %}<p>No original documents attached yet.</p>{% endfor %}<h2>Unresolved Questions</h2><ul>{% for q in case.unresolved_questions %}<li>{{ q }}</li>{% endfor %}</ul><h2>Source URLs</h2><ul>{% for s in case.source_urls %}<li><a href="{{ s.url }}" rel="nofollow">{{ s.label }}</a></li>{% endfor %}</ul><h2>Related Indexed Records</h2>{% for r in related %}<article class="entry"><div class="meta">{{ r.published_date }} · {{ r.source_name }}</div><h3><a href="{{ r.source_url }}" rel="nofollow">{{ r.headline }}</a></h3></article>{% else %}<p>No related scraped records yet.</p>{% endfor %}</main>{% endblock %}
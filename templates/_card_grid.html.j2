{% macro card_grid(items, heading="Related records", intro="", aria_label="Related records", footer_link=None) -%}
{% if items %}<section aria-label="{{ aria_label }}"><h2>{{ heading }}</h2>{% if intro %}<p>{{ intro }}</p>{% endif %}<div class="grid">{% for item in items %}<article class="card"><h3><a href="{{ item.href|default(item.url|default('#')) }}">{{ item.title|default(item.name) }}</a></h3><p>{{ item.tagline|default(item.summary|default('')) }}</p></article>{% endfor %}</div>{% if footer_link %}<p><a href="{{ footer_link.href }}">{{ footer_link.label }}</a></p>{% endif %}</section>{% endif %}
{%- endmacro %}

{% extends "_base.html.j2" %}{% block content %}<main class="container-wide"><div class="breadcrumbs"><a href="/tools">Tools</a> / Evidence Grader</div><h1>UAP Evidence Grader</h1><p class="lede">A simple public-record score based on official records, video, multi-sensor context, official resolution, and source count.</p><div class="grid">{% for c in cases %}<article class="card"><div class="meta">{{ c.status|replace('_',' ') }}</div><h3><a href="/cases/{{ c.slug }}">{{ c.title }}</a></h3><p><strong>{{ grades[c.slug].score }}/100</strong> · {{ grades[c.slug].label }}</p><p>{{ c.official_explanation }}</p></article>{% endfor %}</div></main>{% endblock %}
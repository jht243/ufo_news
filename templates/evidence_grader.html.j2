{% extends "_base.html.j2" %}{% block content %}<main class="container-wide"><div class="breadcrumbs"><a href="/tools">Tools</a> / See Which UFO Cases Have the Best Records</div><div class="eyebrow">Record strength</div><h1>See Which UFO Cases Have the Best Records</h1><p class="lede">Compare incidents by how much public material exists: official documents, videos, sensor details, explanations, and links to original sources.</p><section class="search-panel"><div class="grid" style="margin:0"><div><h3>Rubric</h3><p>Official record: 30 · video: 20 · multi-sensor context: 20 · official resolution: 20 · multiple sources: 10.</p></div><div><h3>Interpretation</h3><p>High scores mean the public has stronger documents to inspect. Low scores mean the public trail is thin, not that the claim is false.</p></div></div></section><div class="grid">{% for c in cases %}<article class="card"><div class="meta">{{ c.status|replace('_',' ') }} · {{ c.location }}</div><h3><a href="/cases/{{ c.slug }}">{{ c.title }}</a></h3><p><strong>{{ grades[c.slug].score }}/100</strong> · {{ grades[c.slug].label }}</p><p>{{ c.official_explanation }}</p><p><span class="pill">{{ c.documents|length }} documents</span><span class="pill">{{ c.claims|length }} stories people ask about</span>{% if c.evidence.official_record %}<span class="pill">official record</span>{% endif %}{% if c.evidence.video %}<span class="pill">video</span>{% endif %}{% if c.evidence.multi_sensor %}<span class="pill">multi-sensor</span>{% endif %}{% if c.evidence.official_resolution %}<span class="pill">official resolution</span>{% endif %}</p>{% if c.documents %}<p><strong>Primary source:</strong> <a href="{{ c.documents[0].url }}" rel="nofollow">{{ c.documents[0].title }}</a></p>{% endif %}</article>{% endfor %}</div></main>{% endblock %}

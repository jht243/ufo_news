<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% set _seo = seo|default({}) %}
  <title>{{ _seo.title|default('The UAP Index - Daily UAP Briefing') }}</title>
  <meta name="description" content="{{ _seo.description|default('Daily UAP briefing, case files, document finder, and claim checker.') }}">
  <meta name="keywords" content="{{ _seo.keywords|default('UAP, UFO, AARO, NARA UAP, UAP documents, UAP cases, UFO claim checker') }}">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1">
  <link rel="canonical" href="{{ _seo.canonical|default('') }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="The UAP Index">
  <meta property="og:title" content="{{ _seo.title|default('The UAP Index') }}">
  <meta property="og:description" content="{{ _seo.description|default('') }}">
  <meta property="og:image" content="{{ _seo.og_image|default('') }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Open+Sans:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
  {% if jsonld %}<script type="application/ld+json">{{ jsonld|safe }}</script>{% endif %}
  <style>
    :root { --sr-blue:#002b5e; --sr-blue-light:#1a4170; --sr-blue-dark:#001f44; --sr-red:#cc0000; --sr-gray-bg:#f8f9fa; --sr-gray-light:#e9ecef; --sr-gray-text:#6c757d; --sr-dark-text:#212529; --white:#fff; --status-red:#cc0000; --status-red-bg:#ffe6e6; --status-green:#0b8043; --status-green-bg:#e6f4ea; --status-yellow:#f5b041; --status-yellow-bg:#fef5e6; --font-serif:'Libre Baskerville','Times New Roman',serif; --font-sans:'Open Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif; }
    *{margin:0;padding:0;box-sizing:border-box} html{scroll-behavior:smooth} body{font-family:var(--font-sans);background:var(--white);color:var(--sr-dark-text);line-height:1.6;font-size:16px;-webkit-font-smoothing:antialiased} a{color:var(--sr-blue);text-decoration:none} a:hover{text-decoration:underline}
    .top-nav{background:var(--sr-blue);color:var(--white);padding:12px 0}.top-nav-container{max-width:1140px;margin:0 auto;padding:0 20px;display:flex;justify-content:space-between;align-items:center}.nav-brand{font-family:var(--font-serif);font-size:1.25rem;font-weight:700;letter-spacing:.5px;color:var(--white);display:flex;align-items:center;gap:12px;text-decoration:none}.nav-brand svg{width:30px;height:30px}.nav-links{display:flex;align-items:center;gap:24px;font-size:.85rem;font-weight:700;text-transform:uppercase;letter-spacing:1px}.nav-links a{color:#fff;text-decoration:none}.nav-login{background:var(--sr-red);padding:8px 16px;border-radius:3px}
    .ticker-bar{background:var(--sr-blue-dark);color:#fff;overflow:hidden;border-bottom:1px solid rgba(255,255,255,.1)}.ticker-inner{max-width:1140px;margin:0 auto;padding:0 20px;display:flex;align-items:center;height:40px;overflow-x:auto;scrollbar-width:none}.ticker-item{display:flex;align-items:center;gap:8px;padding:0 20px;white-space:nowrap;font-size:.78rem;font-weight:600;border-right:1px solid rgba(255,255,255,.15);flex-shrink:0}.ticker-label{opacity:.62;text-transform:uppercase;letter-spacing:.5px;font-size:.65rem}.ticker-value{font-family:'Courier New',monospace;font-size:.85rem}.ticker-source{font-size:.6rem;opacity:.45;margin-left:4px;font-style:italic}
    .hero{background:var(--sr-gray-bg);padding:40px 20px 30px;text-align:center;border-bottom:1px solid var(--sr-gray-light)}.hero h1{font-family:var(--font-serif);font-size:2.8rem;font-weight:700;color:var(--sr-blue);max-width:820px;margin:0 auto 18px;line-height:1.25}.hero .subtitle{font-size:1.15rem;color:var(--sr-gray-text);max-width:720px;margin:0 auto;line-height:1.6}.hero .subtitle strong{color:var(--sr-blue-dark)}
    .climate-panel{max-width:1140px;margin:0 auto;padding:0 20px}.climate-box{background:#fff;border:1px solid var(--sr-gray-light);border-top:4px solid var(--sr-blue);margin-top:24px;padding:28px 36px;box-shadow:0 4px 15px rgba(0,0,0,.03)}.climate-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:20px}.climate-header h3{font-family:var(--font-serif);font-size:1.2rem;color:var(--sr-blue)}.climate-period{font-size:.75rem;color:var(--sr-gray-text);font-weight:700}.climate-bars{display:grid;grid-template-columns:1fr 1fr;gap:18px 40px}.bar-label{font-size:.82rem;font-weight:700;color:var(--sr-dark-text)}.bar-top{display:flex;justify-content:space-between;margin-bottom:6px}.bar-score{font-family:'Courier New',monospace;font-size:.82rem;font-weight:800}.bar-track{height:8px;background:var(--sr-gray-light);border-radius:4px;overflow:hidden}.bar-fill{height:100%;border-radius:4px}.bar-blue{background:var(--sr-blue)}.bar-green{background:var(--status-green)}.bar-yellow{background:var(--status-yellow)}.bar-red{background:var(--status-red)}.bar-why{font-size:.7rem;color:var(--sr-gray-text);margin-top:4px;line-height:1.4;font-style:italic}.climate-footer{font-size:.7rem;color:var(--sr-gray-text);border-top:1px solid var(--sr-gray-light);padding-top:12px;margin-top:20px;line-height:1.5}
    .main-panel{max-width:1140px;margin:16px auto 0;padding:0 20px}.two-col-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px}.calendar-box,.panel-box{background:#fff;border:1px solid var(--sr-gray-light);padding:24px 36px;box-shadow:0 4px 15px rgba(0,0,0,.03)}.calendar-box h3,.panel-header h3{font-family:var(--font-serif);font-size:1.2rem;color:var(--sr-blue);margin-bottom:16px}.cal-timeline,.news-timeline{position:relative;padding-left:20px}.cal-timeline:before,.news-timeline:before{content:'';position:absolute;left:6px;top:0;bottom:0;width:2px;background:var(--sr-gray-light)}.cal-event,.news-item{position:relative;padding:10px 0 10px 24px;font-size:.88rem;line-height:1.5}.cal-event:before,.news-item:before{content:'';position:absolute;left:-1px;top:16px;width:10px;height:10px;border-radius:50%;border:2px solid var(--sr-blue);background:#fff}.cal-date{font-weight:800;color:var(--sr-blue);font-size:.78rem;text-transform:uppercase;letter-spacing:.5px}.cal-note,.news-note{color:var(--sr-gray-text);font-size:.78rem;font-style:italic}.news-link{display:block;color:inherit;padding:4px 8px;margin:-4px -8px;border-radius:4px}.news-link:hover{background:var(--sr-gray-bg);text-decoration:none}
    .panel-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}.sector-select{font-family:var(--font-sans);font-size:.82rem;font-weight:700;color:var(--sr-blue);padding:6px 32px 6px 12px;border:1px solid var(--sr-gray-light);border-radius:3px;background:var(--sr-gray-bg)}.entries-container{margin-top:16px}.entry{background:#fff;border-bottom:1px solid var(--sr-gray-light);transition:background .2s}.entry:hover{background:#fcfcfd}.entry.hidden{display:none}.entry-header{padding:20px 0 12px}.pill-row{display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap}.category-label{font-size:.75rem;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--sr-blue)}.badge-new{font-size:.6rem;font-weight:800;text-transform:uppercase;letter-spacing:1px;padding:2px 8px;border-radius:3px;background:var(--sr-red);color:#fff}.status-pill{font-size:.7rem;font-weight:800;text-transform:uppercase;padding:4px 10px;border-radius:20px;display:inline-flex;align-items:center;gap:6px}.status-passed,.status-resolved{background:var(--status-green-bg);color:var(--status-green)}.status-progress,.status-under_review{background:var(--status-yellow-bg);color:#d97706}.status-announced,.status-official_release{background:#e0f2fe;color:#2563eb}.status-monitoring,.status-media_report,.status-witness_report,.status-contested,.status-unresolved{background:var(--sr-gray-light);color:var(--sr-gray-text)}.status-dot{width:6px;height:6px;border-radius:50%;background:currentColor}.entry-header h3{font-family:var(--font-serif);font-size:1.2rem;color:var(--sr-dark-text);line-height:1.3;margin-bottom:4px}.entry-meta{font-size:.85rem;color:var(--sr-gray-text);display:flex;align-items:center;gap:16px;flex-wrap:wrap}.entry-meta a{font-weight:700}.source-trust{font-size:.7rem;padding:2px 8px;border-radius:3px;font-weight:700}.trust-official{background:#e0f2fe;color:#1d4ed8}.trust-research,.trust-foia{background:#edf2ff;color:#3730a3}.trust-witness{background:#fef3c7;color:#92400e}.trust-news{background:var(--sr-gray-light);color:var(--sr-gray-text)}.entry-body{padding:0 0 20px}.takeaway-header{font-size:.85rem;font-weight:800;color:var(--sr-red);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;display:flex;justify-content:space-between}.takeaway{font-size:1.05rem;line-height:1.7;margin-bottom:14px}.sentiment-badge{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:4px;font-size:.75rem;font-weight:800;text-transform:uppercase;background:var(--status-yellow-bg);color:#d97706}.entry-actions{margin-top:10px;display:flex;align-items:center;gap:14px;flex-wrap:wrap}.footer{background:var(--sr-blue-dark);color:#fff;padding:40px 20px;text-align:center;font-size:.85rem;line-height:1.8;margin-top:40px}.footer p{opacity:.8;max-width:800px;margin:0 auto}
    @media(max-width:768px){.top-nav-container{flex-wrap:wrap}.nav-links{gap:14px;font-size:.75rem}.hero h1{font-size:2.2rem}.climate-bars,.two-col-row{grid-template-columns:1fr}.calendar-box,.panel-box,.climate-box{padding:20px}}
  </style>
</head>
<body>
<div class="top-nav"><div class="top-nav-container"><a href="/" class="nav-brand">{% include "_brand_logo.svg" %}The UAP Index</a><div class="nav-links"><a href="/briefing">Briefing</a><a href="/cases">Cases</a><a href="/documents">Documents</a><a href="/tools">Tools</a><a href="/timeline">Timeline</a><a href="/sources">Sources</a><a href="/tools/uap-claim-checker" class="nav-login">Check Claim</a></div></div></div>
<div class="ticker-bar"><div class="ticker-inner">{% for item in ticker_items %}<div class="ticker-item"><span class="ticker-label">{{ item.label }}</span><span class="ticker-value">{{ item.value }}</span><span class="ticker-source">{{ item.note }}</span></div>{% endfor %}</div></div>
<div class="hero"><h1>The Daily UAP Briefing</h1><div class="subtitle"><strong>Official records, case files, FOIA archives, witness databases, and news</strong> organized into a source-labeled index for people trying to understand what is actually documented.</div></div>
<div class="climate-panel"><div class="climate-box"><div class="climate-header"><h3>Public Evidence Dashboard</h3><span class="climate-period">Generated {{ generated_at }}</span></div><div class="climate-bars"><div class="bar-item"><div class="bar-top"><span class="bar-label">Indexed source records</span><span class="bar-score">{{ entries|length }}</span></div><div class="bar-track"><div class="bar-fill bar-blue" style="width:{{ [entries|length * 8, 100]|min }}%"></div></div><div class="bar-why">Fresh scraper/analyzer rows appear here; curated cases fill the feed when the live corpus is empty.</div></div><div class="bar-item"><div class="bar-top"><span class="bar-label">Seeded case files</span><span class="bar-score">{{ cases|length }}</span></div><div class="bar-track"><div class="bar-fill bar-green" style="width:100%"></div></div><div class="bar-why">GoFast, Gimbal, Tic Tac, Puerto Rico, Eglin, Al Taqaddum, and other case files are available immediately.</div></div><div class="bar-item"><div class="bar-top"><span class="bar-label">Resolved case ratio</span><span class="bar-score">{{ ticker_items[3].value }}</span></div><div class="bar-track"><div class="bar-fill bar-yellow" style="width:60%"></div></div><div class="bar-why">Resolution means a public official explanation exists in the seeded record; it does not mean every question is closed.</div></div><div class="bar-item"><div class="bar-top"><span class="bar-label">Claim-check readiness</span><span class="bar-score">Live</span></div><div class="bar-track"><div class="bar-fill bar-blue" style="width:90%"></div></div><div class="bar-why">The claim checker searches seeded cases plus scraped records as the daily corpus grows.</div></div></div><div class="climate-footer"><strong>Methodology:</strong> Items are labeled by source class, evidence level, official status, and unresolved gaps. A record or mention is not treated as proof beyond the linked material.</div></div></div>
<div class="main-panel"><div class="two-col-row"><div class="calendar-box"><h3>Case & Release Timeline</h3><div class="cal-timeline">{% for event in timeline_events[:5] %}<div class="cal-event {{ event.css_class|default('') }}"><div class="cal-date">{{ event.date_label }}</div><div class="cal-desc"><strong>{{ event.title }}</strong></div><div class="cal-note">{{ event.note }}</div></div>{% endfor %}</div></div><div class="panel-box"><div class="panel-header"><h3>Fast Tools</h3></div><div class="news-timeline"><div class="news-item"><a class="news-link" href="/tools/uap-claim-checker?q=GoFast"><div class="news-headline"><strong>Claim checker</strong> - paste a case, claim, or video title.</div><div class="news-note">Try GoFast, Gimbal, or triangle lights.</div></a></div><div class="news-item"><a class="news-link" href="/tools/uap-document-finder"><div class="news-headline"><strong>Document finder</strong> - filter AARO, NARA, FOIA, and news records.</div><div class="news-note">Works now; grows as scrapers add records.</div></a></div><div class="news-item"><a class="news-link" href="/tools/uap-evidence-grader"><div class="news-headline"><strong>Evidence grader</strong> - compare public-record strength.</div><div class="news-note">Transparent score, no hype.</div></a></div></div></div></div>
<div class="panel-box"><div class="panel-header"><h3>Latest UAP Records & Case Files</h3><select id="sectorFilter" class="sector-select"><option value="all">All</option>{% for f in filters %}<option value="{{ f.value }}">{{ f.label }}</option>{% endfor %}</select></div><div class="entries-container">{% for entry in entries %}<div class="entry" id="dev-{{ entry.id }}" data-sectors="{{ entry.tags }}"><div class="entry-header"><div class="pill-row"><span class="category-label">{{ entry.evidence_level|replace('_',' ') }}</span>{% if loop.index <= 3 %}<span class="badge-new">Featured</span>{% endif %}<span class="status-pill status-{{ entry.status }}"><span class="status-dot"></span>{{ entry.status|replace('_',' ') }}</span></div><h3>{{ entry.headline_short }}</h3><div class="entry-meta"><span>{{ entry.date_display }}</span><span>{{ entry.agency_tags|join(', ') }}</span><a href="{{ entry.source_url }}">{{ entry.source_display }} &rarr;</a><span class="source-trust trust-{{ entry.source_trust }}">{{ entry.confidence_label }}</span></div></div><div class="entry-body"><div class="takeaway-header"><span>Why it matters</span><span class="sentiment-badge">Source-labeled</span></div><div class="takeaway">{{ entry.takeaway }}</div><div class="entry-actions">{% if entry.blog_slug %}<a href="/briefing/{{ entry.blog_slug }}" style="color:#cc0000;font-weight:700">Read full briefing &rarr;</a>{% endif %}{% if entry.source_url.startswith('/cases/') %}<a href="{{ entry.source_url }}" style="color:#cc0000;font-weight:700">Open case file &rarr;</a>{% endif %}<a href="/tools/uap-claim-checker?q={{ entry.case_names[0]|urlencode if entry.case_names else entry.headline_short|urlencode }}">Check related claim &rarr;</a></div></div></div>{% endfor %}</div></div></div>
<footer class="footer"><p>&copy; {{ current_year }} The UAP Index. Source-labeled public-record navigation, not proof beyond cited materials. Generated {{ generated_at }}.</p></footer>
<script>const filter=document.getElementById('sectorFilter');if(filter){filter.addEventListener('change',()=>{const f=filter.value;document.querySelectorAll('.entry').forEach(e=>{e.classList.toggle('hidden',f!=='all'&&!(e.dataset.sectors||'').includes(f));});});}</script>
</body></html>

<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>{{ seo.title }}</title><meta name="description" content="{{ seo.description }}"><link rel="canonical" href="{{ seo.canonical }}"><script type="application/ld+json">{{ jsonld|safe }}</script><style>
:root{--ink:#152033;--muted:#617089;--line:#dbe3ef;--wash:#f6f8fb;--blue:#183a66;--red:#b3262f;--green:#167044;--gold:#9a6a00;--serif:Georgia,"Times New Roman",serif;--font:Inter,ui-sans-serif,system-ui,-apple-system,"Segoe UI",sans-serif}*{box-sizing:border-box}body{margin:0;font-family:var(--font);color:var(--ink);line-height:1.6}.top{background:var(--blue);color:#fff}.nav{max-width:1120px;margin:0 auto;padding:14px 22px;display:flex;justify-content:space-between;gap:18px;align-items:center}.brand{font-family:var(--serif);font-size:22px;font-weight:700;color:#fff;text-decoration:none}.links{display:flex;gap:16px;flex-wrap:wrap}.links a{color:#fff;text-decoration:none;font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:.08em}.ticker{background:#0f253f;color:#fff}.ticker-inner{max-width:1120px;margin:0 auto;display:flex;gap:0;overflow:auto;padding:0 22px}.ticker-item{padding:10px 18px;border-right:1px solid rgba(255,255,255,.18);white-space:nowrap}.ticker-label{font-size:11px;opacity:.7;text-transform:uppercase;letter-spacing:.1em}.ticker-value{font-weight:800;margin-left:8px}.hero{background:var(--wash);border-bottom:1px solid var(--line);text-align:center;padding:44px 22px}.hero h1{font-family:var(--serif);font-size:46px;line-height:1.15;margin:0 0 12px}.hero p{max-width:720px;margin:0 auto;color:var(--muted);font-size:18px}.wrap{max-width:1120px;margin:0 auto;padding:28px 22px}.filters{display:flex;gap:8px;flex-wrap:wrap;margin:0 0 18px}.filters button{border:1px solid var(--line);background:#fff;padding:8px 12px;border-radius:999px;font-weight:700;color:var(--blue);cursor:pointer}.grid{display:grid;grid-template-columns:2fr 1fr;gap:28px}.entry{border-bottom:1px solid var(--line);padding:22px 0}.entry h2{font-family:var(--serif);font-size:25px;margin:0 0 8px}.meta{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em}.pill{display:inline-flex;border-radius:999px;border:1px solid var(--line);padding:3px 9px;font-size:12px;font-weight:700;color:var(--blue);margin:2px 4px 2px 0}.takeaway{font-size:17px}.side{background:var(--wash);border:1px solid var(--line);padding:18px;height:max-content}.case-row{border-bottom:1px solid var(--line);padding:10px 0}.case-row:last-child{border-bottom:0}.footer{background:#10233c;color:#d7e0ef;text-align:center;padding:24px;font-size:13px}.footer a{color:#fff}@media(max-width:850px){.grid{grid-template-columns:1fr}.hero h1{font-size:34px}.nav{flex-direction:column;align-items:flex-start}}
</style></head><body><nav class="top"><div class="nav"><a class="brand" href="/">The UAP Index</a><div class="links"><a href="/briefing">Briefing</a><a href="/cases">Cases</a><a href="/documents">Documents</a><a href="/tools">Tools</a><a href="/timeline">Timeline</a><a href="/sources">Sources</a></div></div></nav><section class="ticker"><div class="ticker-inner">{% for t in ticker_items %}<div class="ticker-item"><span class="ticker-label">{{ t.label }}</span><span class="ticker-value">{{ t.value }}</span><span class="ticker-label"> {{ t.note }}</span></div>{% endfor %}</div></section><header class="hero"><h1>Daily UAP Briefing</h1><p>Source-labeled updates from official records, UAP research outlets, witness databases, and news. Built to help readers navigate claims, cases, and documents without losing the evidence trail.</p></header><main class="wrap"><div class="filters"><button data-filter="all">All</button>{% for f in filters %}<button data-filter="{{ f.value }}">{{ f.label }}</button>{% endfor %}</div><div class="grid"><section>{% if entries %}{% for e in entries %}<article class="entry" data-tags="{{ e.tags }}"><div class="meta">{{ e.date_display }} · {{ e.source_display }} · {{ e.confidence_label }}</div><h2>{{ e.headline_short }}</h2><div>{% for c in e.case_names %}<span class="pill">{{ c }}</span>{% endfor %}<span class="pill">{{ e.evidence_level|replace('_',' ') }}</span><span class="pill">{{ e.status|replace('_',' ') }}</span></div><p class="takeaway">{{ e.takeaway }}</p><p><a href="{{ e.source_url }}" rel="nofollow">Primary source</a>{% if e.blog_slug %} · <a href="/briefing/{{ e.blog_slug }}">Read full briefing</a>{% endif %}</p></article>{% endfor %}{% else %}<article class="entry"><h2>No analyzed UAP items yet</h2><p>Run the daily pipeline to populate this feed. The seeded case tools are available now.</p></article>{% endif %}</section><aside class="side"><h2>Case Resolver</h2>{% for c in cases[:8] %}<div class="case-row"><strong><a href="/cases/{{ c.slug if c.slug is defined else c['slug'] }}">{{ c.title if c.title is defined else c['title'] }}</a></strong><br><span class="meta">{{ c.status if c.status is defined else c['status'] }}</span></div>{% endfor %}<p><a href="/tools/uap-claim-checker">Open the claim checker</a></p></aside></div></main><footer class="footer"><p>Generated {{ generated_at }} · <a href="/sources">Sources and methodology</a></p></footer><script>document.querySelectorAll('[data-filter]').forEach(b=>b.addEventListener('click',()=>{const f=b.dataset.filter;document.querySelectorAll('.entry[data-tags]').forEach(e=>{e.style.display=(f==='all'||e.dataset.tags.includes(f))?'block':'none'})}))</script></body></html>
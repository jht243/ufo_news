{% macro recent_briefings_rail(posts, heading="Latest briefings", intro="Recent source-labeled UAP briefings.") -%}
{% if posts %}<section><h2>{{ heading }}</h2><p>{{ intro }}</p>{% for p in posts %}<article class="entry"><h3><a href="/briefing/{{ p.slug }}">{{ p.title }}</a></h3><p>{{ p.summary }}</p></article>{% endfor %}</section>{% endif %}
{%- endmacro %}

{#
  Reusable "Latest related briefings" rail.

  Why this partial exists:
    Per-page bespoke briefing rails were drifting in style, and each
    page that wanted internal-link signal into individual /briefing/<slug>
    pages had to re-implement the markup. The 2026-04 indexing audit
    flagged that briefings only had inbound links from /briefing
    (the chronological index, which Google deprioritises as it ages),
    so we want every steady-traffic page (tools, sanctions tracker,
    sector pages) to feed crawl signal into the briefings.

  Inputs:
    recent_briefings : list of BlogPost rows with .slug, .title,
                       .published_date, optional .summary
    heading          : section heading; defaults to "Latest analysis"
    intro            : optional short paragraph above the list

  Render no-ops if recent_briefings is empty so callers can pass it
  unconditionally.
#}
{% macro recent_briefings_rail(recent_briefings, heading="Latest analysis", intro=None) -%}
{%- if recent_briefings %}
<section style="margin: 32px 0; padding: 20px 24px; background: var(--sr-gray-bg); border-left: 3px solid var(--sr-blue);">
  <h2 style="font-family: var(--font-serif); font-size: 22px; color: var(--sr-blue-dark); margin: 0 0 6px;">
    {{ heading }}
  </h2>
  {% if intro %}
  <p style="font-size: 13px; color: var(--sr-gray-text); margin: 0 0 14px;">{{ intro }}</p>
  {% endif %}
  <ul style="list-style: none; padding: 0; margin: 0;">
    {% for r in recent_briefings %}
    <li style="padding: 10px 0; border-bottom: 1px solid var(--sr-gray-light);">
      <a href="/briefing/{{ r.slug }}" style="color: var(--sr-blue-dark); font-weight: 600; text-decoration: none;">{{ r.title }}</a>
      <small style="display: block; color: var(--sr-gray-text); font-size: 12px; margin-top: 2px;">
        {{ r.published_date.strftime('%b %d, %Y') }}
      </small>
    </li>
    {% endfor %}
  </ul>
  <p style="margin: 14px 0 0; font-size: 13px;">
    <a href="/briefing" style="color: var(--sr-blue);">Browse all daily briefings &rarr;</a>
  </p>
</section>
{%- endif %}
{%- endmacro %}

{% extends "_base.html.j2" %}
{% from "_base.html.j2" import share_button %}

{% block head_extra %}
<style>
  .vdl-wrap { max-width: 720px; margin: 0 auto; }
  .vdl-hero { margin: 16px 0 24px; }
  .vdl-hero .kicker { font-size: 12px; text-transform: uppercase; letter-spacing: 1.2px; color: var(--sr-red); font-weight: 700; margin-bottom: 6px; }
  .vdl-hero h1 { font-family: var(--font-serif); font-size: 32px; color: var(--sr-blue-dark); margin: 0 0 12px; line-height: 1.2; }
  .vdl-hero .lead { font-family: var(--font-serif); font-size: 17px; color: var(--sr-dark-text); line-height: 1.55; margin: 0 0 18px; }
  .vdl-cta-row { display: flex; flex-wrap: wrap; gap: 10px; margin: 18px 0 22px; }
  .vdl-cta { display: inline-block; background: var(--sr-red); color: #fff; padding: 12px 20px; border-radius: 3px; text-decoration: none; font-weight: 700; font-size: 15px; }
  .vdl-cta:hover { background: #a01d18; color: #fff; }
  .vdl-section { margin: 28px 0 0; }
  .vdl-section h2 { font-family: var(--font-serif); font-size: 22px; color: var(--sr-blue-dark); margin: 0 0 10px; }
  .vdl-section p { font-size: 15px; color: var(--sr-dark-text); line-height: 1.65; margin: 0 0 12px; }
  .vdl-section a { color: var(--sr-blue); font-weight: 600; }
  .vdl-see { margin: 32px 0 0; padding: 16px 18px; background: var(--sr-gray-bg); border-left: 3px solid var(--sr-blue); border-radius: 3px; }
  .vdl-see h3 { font-family: var(--font-serif); font-size: 17px; color: var(--sr-blue-dark); margin: 0 0 10px; }
  .vdl-see ul { margin: 0; padding-left: 20px; font-size: 15px; line-height: 1.7; }
  .vdl-see a { color: var(--sr-blue); font-weight: 600; }
</style>
{% endblock %}

{% block content %}
<section class="container">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/travel">Travel to Venezuela</a><span>/</span>
    <span>{{ page.h1 }}</span>
    <span style="margin-left:auto;">{{ share_button(seo.canonical, seo.title) }}</span>
  </nav>

  <div class="vdl-wrap">
    <header class="vdl-hero">
      <div class="kicker">{{ page.kicker }}</div>
      <h1>{{ page.h1 }}</h1>
      <p class="lead">{{ page.lead|safe }}</p>
      <div class="vdl-cta-row">
        <a class="vdl-cta" href="{{ page.tool_url }}">{{ page.tool_label }} &rarr;</a>
      </div>
    </header>

    {% for sec in page.sections %}
    <section class="vdl-section">
      <h2>{{ sec.h2 }}</h2>
      {% for p in sec.paragraphs %}
      <p>{{ p|safe }}</p>
      {% endfor %}
    </section>
    {% endfor %}

    <div class="vdl-cta-row" style="margin-top: 28px;">
      <a class="vdl-cta" href="{{ page.tool_url }}">{{ page.tool_label }} &rarr;</a>
    </div>

    <div class="vdl-see">
      <h3>See also</h3>
      <ul>
        {% for link in page.nav_links %}
        <li><a href="{{ link.href }}">{{ link.label }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>
{% endblock %}

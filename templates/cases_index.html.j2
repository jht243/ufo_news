{% extends "_base.html.j2" %}{% block content %}<main class="container-wide"><div class="breadcrumbs"><a href="/">Home</a> / Cases</div><h1>{% if tool_mode %}UAP Case Resolver{% else %}UAP Cases{% endif %}</h1><p class="lede">Browse seeded case files with official status, source links, unresolved questions, and evidence grades.</p><form class="search-panel" method="get"><div class="search-row"><input name="q" value="{{ q|default('') }}" placeholder="Search GoFast, Eglin, Tic Tac, Puerto Rico"><button>Search</button></div></form><div class="grid">{% for c in cases %}<article class="card"><div class="meta">{{ c.status|replace('_',' ') }} · {{ grades[c.slug].label }} · {{ grades[c.slug].score }}/100</div><h3><a href="/cases/{{ c.slug }}">{{ c.title }}</a></h3><p>{{ c.location }} · {{ c.event_date }}</p><p>{{ c.official_explanation }}</p></article>{% endfor %}</div></main>{% endblock %}
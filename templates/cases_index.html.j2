{% extends "_base.html.j2" %}{% block content %}<main class="container-wide"><div class="breadcrumbs"><a href="/">Home</a> / Cases</div><div class="eyebrow">{% if tool_mode %}Resolver{% else %}Case directory{% endif %}</div><h1>{% if tool_mode %}UAP Case Resolver{% else %}UAP Cases{% endif %}</h1><p class="lede">Browse cases by official status, region, documents, associated claims, and unresolved gaps.</p>{% if tool_mode %}<form class="search-panel" method="get"><div class="search-row"><input name="q" value="{{ q|default('') }}" placeholder="Search GoFast, Eglin, Tic Tac, Puerto Rico"><select name="status"><option value="">All statuses</option>{% for s in facets.statuses %}<option value="{{ s }}" {% if selected.status==s %}selected{% endif %}>{{ s|replace('_',' ') }}</option>{% endfor %}</select><select name="region"><option value="">All regions</option>{% for r in regions %}<option value="{{ r }}" {% if selected.region==r %}selected{% endif %}>{{ r }}</option>{% endfor %}</select><button>Resolve</button></div></form>{% endif %}<div class="grid">{% for c in cases %}<article class="card"><div class="meta">{{ c.status|replace('_',' ') }} · {{ c.region|default(c.location) }} · {{ grades[c.slug].score }}/100</div><h3><a href="/cases/{{ c.slug }}">{{ c.title }}</a></h3><p>{{ c.location }} · {{ c.event_date }}</p><p>{{ c.official_explanation }}</p><p><span class="pill">{{ c.claims|length }} claims</span><span class="pill">{{ c.documents|length }} documents</span><span class="pill">{{ grades[c.slug].label }}</span></p>{% if c.claims %}<p><strong>Claims:</strong> {% for claim in c.claims[:2] %}{{ claim.claim }}{% if not loop.last %}; {% endif %}{% endfor %}</p>{% endif %}{% if c.documents %}<p><strong>Original docs:</strong> {% for d in c.documents[:2] %}<a href="{{ d.url }}" rel="nofollow">{{ d.source_name }}</a>{% if not loop.last %} · {% endif %}{% endfor %}</p>{% endif %}</article>{% else %}<p>No case files match those filters.</p>{% endfor %}</div></main>{% endblock %}
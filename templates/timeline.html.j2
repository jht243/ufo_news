{% extends "_base.html.j2" %}{% block content %}<main class="container"><div class="breadcrumbs"><a href="/">Home</a> / Timeline</div><h1>UAP Timeline</h1><p class="lede">Cases, official records, hearings, releases, and indexed source events.</p>{% for e in events %}<article class="entry"><div class="meta">{{ e.date_label }} · {{ e.source_name }}</div><h3><a href="{{ e.source_url }}">{{ e.title }}</a></h3><p>{{ e.note }}</p></article>{% endfor %}</main>{% endblock %}
{% extends "_base.html.j2" %}{% block content %}<main class="container-wide"><div class="eyebrow">Free source tools</div><h1>UAP Research Tools</h1><p class="lede">Start with the evidence corpus, then search. Each tool now exposes browsable claims, cases, and original source documents before you type anything.</p><section class="search-panel"><div class="grid" style="margin:0"><div><div class="meta">Claims</div><h2 style="margin:4px 0">{{ stats.claims }}</h2><p>Source-backed claim cards grouped by year, location, category, and case.</p></div><div><div class="meta">Original documents</div><h2 style="margin:4px 0">{{ stats.documents }}</h2><p>AARO PDFs, NARA collection pages, NASA methodology pages, and official indexes.</p></div><div><div class="meta">Cases</div><h2 style="margin:4px 0">{{ stats.cases }}</h2><p>Case files with statuses, unresolved questions, claims, and document trails.</p></div></div></section><div class="grid">{% for t in tools %}<article class="card"><div class="meta">{{ t.category }} · {{ t.count }} indexed</div><h3><a href="{{ t.url }}">{{ t.name }}</a></h3><p>{{ t.summary }}</p><p><a href="{{ t.url }}">Open tool →</a></p></article>{% endfor %}</div><section class="grid"><article class="card"><div class="meta">Claims by year</div>{% for g in claim_groups[:5] %}<p><strong>{{ g.label }}</strong> · {{ g["items"]|length }} claims</p>{% endfor %}</article><article class="card"><div class="meta">Documents by source</div>{% for g in doc_groups %}<p><strong>{{ g.label }}</strong> · {{ g["items"]|length }} documents</p>{% endfor %}</article></section></main>{% endblock %}
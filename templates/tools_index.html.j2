{% extends "_base.html.j2" %}{% block content %}<main class="container-wide"><div class="eyebrow">Free source tools</div><h1>UAP Research Tools</h1><p class="lede">Start with the evidence corpus, then search. Each tool opens a focused workspace for checking stories, browsing incidents, finding source documents, or understanding government programs.</p><div class="grid">{% for t in tools %}<article class="card"><div class="meta">{{ t.category }}{% if t.count is not none %} · {{ t.count }} indexed{% endif %}</div><h3><a href="{{ t.url }}">{{ t.name }}</a></h3><p>{{ t.summary }}</p><p><a href="{{ t.url }}">{% if t.count is not none %}Open tool{% else %}Open guide{% endif %} →</a></p></article>{% endfor %}</div></main>{% endblock %}

{% extends "_base.html.j2" %}{% block content %}<main class="container"><h1>UAP Briefings</h1><p class="lede">Source-labeled briefings generated from indexed UAP records and news.</p>{% for p in posts %}<article class="entry"><div class="meta">{{ p.published_date }} · {{ p.primary_sector|default('source record') }}</div><h3><a href="/briefing/{{ p.slug }}">{{ p.title }}</a></h3><p>{{ p.summary }}</p></article>{% else %}<p>No briefings yet. Run the pipeline after scraping sources.</p>{% endfor %}</main>{% endblock %}